---
import { getRelativeLocaleUrl } from "astro:i18n";
import IconHash from "@/assets/icons/IconHash.svg";
import config from "@/config";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
  count?: number;
  linked?: boolean;
};

const { tag, tagName, size = "lg", count, linked = true } = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;

const classList = [
  "flex items-center gap-0.5",
  "border-foreground border-b-2 border-dashed",
  "hover:border-accent hover:text-accent hover:-mt-0.5",
  "focus-visible:text-accent focus-visible:border-none",
  { "text-sm": size === "sm" },
  { "text-lg": size === "lg" },
  { "text-muted-foreground border-muted-foreground/40 hover:mt-0": !linked },
];
---

<li>
  {
    linked ? (
      <a
        href={getRelativeLocaleUrl(locale, `tags/${tag}/`)}
        transition:name={tag}
        class:list={classList}
      >
        <IconHash
          class:list={[
            "opacity-80",
            { "size-5": size === "lg" },
            { "size-4": size === "sm" },
          ]}
        />
        {tagName}
        {count && <span class="text-muted-foreground text-xs">({count})</span>}
      </a>
    ) : (
      <span class:list={classList} title="글 내부 키워드">
        <IconHash
          class:list={[
            "opacity-80",
            { "size-5": size === "lg" },
            { "size-4": size === "sm" },
          ]}
        />
        {tagName}
      </span>
    )
  }
</li>

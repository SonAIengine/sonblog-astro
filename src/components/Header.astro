---
import { getRelativeLocaleUrl } from "astro:i18n";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconX from "@/assets/icons/IconX.svg";
import { stripBase, stripLocale } from "@/utils/withBase";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { site, features } = config;

const routeLocale =
  Astro.url.pathname === "/en/" || Astro.url.pathname.startsWith("/en/")
    ? "en"
    : config.site.lang;
const locale =
  routeLocale === "en" ? routeLocale : (Astro.currentLocale ?? routeLocale);
const t = useTranslations(locale);

// Strip the base prefix so isActive comparisons work regardless of deploy subdirectory.
// e.g. with base "/blog": "/blog/posts/slug" → "/posts/slug"
const relativePath = stripBase(Astro.url.pathname);
const pathWithoutTrailingSlash =
  relativePath.endsWith("/") && relativePath !== "/"
    ? relativePath.slice(0, -1)
    : relativePath;

const currentPath = stripLocale(pathWithoutTrailingSlash, locale);
const isEnglishRoute = locale === "en";
const englishHomePath = "/en/";
const koreanHomePath = "/";
const languageKoHref = isEnglishRoute ? koreanHomePath : Astro.url.pathname;
const languageEnHref = isEnglishRoute ? Astro.url.pathname : englishHomePath;
const navHref = (path: string) =>
  path === "" && isEnglishRoute
    ? englishHomePath
    : getRelativeLocaleUrl(config.site.lang, path);
const portfolioHref = isEnglishRoute
  ? "/portfolio-en/"
  : getRelativeLocaleUrl(config.site.lang, "portfolio");

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());
  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="bg-background text-accent absolute inset-s-16 -top-full z-50 px-3 py-2 backdrop-blur-lg transition-all focus:top-4"
>
  {t.a11y.skipToContent}
</a>

<header
  class="app-layout flex flex-col items-center justify-between sm:flex-row"
>
  <div
    class="border-border bg-background relative flex w-full items-center justify-between border-b py-4 sm:py-6"
  >
    <a
      href={navHref("")}
      class="absolute py-1 text-xl leading-8 font-semibold whitespace-nowrap sm:static sm:my-auto sm:text-2xl sm:leading-none"
    >
      {site.title}
    </a>
    <nav
      id="nav-menu"
      class="relative flex w-full justify-end sm:ms-2 sm:flex-row sm:items-center sm:justify-end sm:space-x-4 sm:py-0"
      aria-label="Primary navigation"
    >
      <button
        id="menu-btn"
        class="focus-outline hover:border-border hover:bg-muted/60 inline-flex size-11 items-center justify-center rounded-md border border-transparent p-2 transition sm:hidden"
        aria-label={t.a11y.openMenu}
        aria-expanded="false"
        aria-controls="menu-items"
        data-label-open={t.a11y.openMenu}
        data-label-close={t.a11y.closeMenu}
      >
        <IconX id="close-icon" class="hidden" />
        <IconMenuDeep id="menu-icon" />
      </button>
      <ul
        id="menu-items"
        class="border-border bg-background [&>li>a]:hover:bg-muted/60 [&>li>a]:hover:text-accent absolute top-[calc(100%+0.5rem)] right-0 z-50 hidden w-[min(18rem,calc(100vw-2rem))] grid-cols-2 gap-1 rounded-md border p-2 shadow-lg shadow-black/10 sm:static sm:mt-0 sm:flex sm:w-auto sm:gap-x-5 sm:gap-y-0 sm:border-0 sm:bg-transparent sm:p-0 sm:shadow-none sm:[&>li]:h-8 [&>li>a]:block [&>li>a]:rounded-md [&>li>a]:px-3 [&>li>a]:py-3 [&>li>a]:text-left [&>li>a]:font-medium [&>li>a]:transition sm:[&>li>a]:px-1.5 sm:[&>li>a]:py-1 sm:[&>li>a]:text-center sm:[&>li>a]:hover:bg-transparent"
      >
        <li class="col-span-2">
          <a
            href={navHref("posts")}
            class:list={{ "active-nav": isActive("/posts") }}
          >
            {t.nav.posts}
          </a>
        </li>
        <li class="col-span-2">
          <a
            href={navHref("topics")}
            class:list={{ "active-nav": isActive("/topics") }}
          >
            Topics
          </a>
        </li>
        <li class="col-span-2">
          <a
            href={navHref("graph")}
            class:list={{ "active-nav": isActive("/graph") }}
          >
            Graph
          </a>
        </li>
        <li class="col-span-2">
          <a
            href={portfolioHref}
            class:list={{ "active-nav": isActive("/portfolio") }}
          >
            Portfolio
          </a>
        </li>
        {
          features.showArchives && (
            <li class="col-span-2">
              <a
                href={navHref("archives")}
                class:list={{ "active-nav": isActive("/archives") }}
              >
                {t.nav.archives}
              </a>
            </li>
          )
        }
        {
          features.search !== false && (
            <li class="col-span-2 flex items-center justify-center sm:ms-1 sm:border-s sm:ps-4">
              <a
                href={navHref("search")}
                class:list={[
                  "focus-outline border-border/80 bg-muted/40 hover:border-accent/50 hover:bg-muted/70 sm:hover:bg-muted/60 flex! h-12 w-full items-center! justify-start! gap-2 rounded-md border px-3! text-left text-xs font-medium transition sm:size-8 sm:justify-center! sm:border-0 sm:bg-transparent sm:p-0!",
                  {
                    "text-accent bg-muted/70 sm:bg-muted/60":
                      isActive("/search"),
                  },
                ]}
                title={t.nav.search}
                aria-label={t.nav.search}
              >
                <IconSearch class="size-5 sm:size-6" />
                <span class="whitespace-nowrap sm:sr-only">{t.nav.search}</span>
              </a>
            </li>
          )
        }
        <li class="col-span-2 flex items-center justify-center sm:ms-1">
          <div
            class="border-border/80 bg-muted/40 flex h-12 w-full items-center rounded-md border p-1 text-xs font-semibold sm:h-8 sm:w-auto"
            aria-label="Language"
          >
            <a
              href={languageKoHref}
              data-lang-choice="ko"
              aria-current={isEnglishRoute ? undefined : "page"}
              class:list={[
                "focus-outline flex flex-1 items-center justify-center rounded px-2 py-2 transition sm:min-w-8 sm:py-1",
                {
                  "bg-background text-foreground shadow-sm": !isEnglishRoute,
                  "text-muted-foreground hover:text-accent": isEnglishRoute,
                },
              ]}
            >
              KO
            </a>
            <a
              href={languageEnHref}
              data-lang-choice="en"
              aria-current={isEnglishRoute ? "page" : undefined}
              class:list={[
                "focus-outline flex flex-1 items-center justify-center rounded px-2 py-2 transition sm:min-w-8 sm:py-1",
                {
                  "bg-background text-foreground shadow-sm": isEnglishRoute,
                  "text-muted-foreground hover:text-accent": !isEnglishRoute,
                },
              ]}
            >
              EN
            </a>
          </div>
        </li>
        {
          features.lightAndDarkMode && (
            <li class="col-span-2 flex items-center justify-center">
              <button
                id="theme-btn"
                class="focus-outline hover:border-accent/50 hover:bg-muted/70 border-border/80 bg-muted/40 hover:[&>span>svg]:stroke-accent relative flex h-12 w-full items-center justify-start gap-2 rounded-md border px-3! text-left text-xs font-medium transition sm:size-8 sm:justify-center sm:border-0 sm:bg-transparent sm:p-0 sm:hover:bg-transparent"
                title={t.a11y.toggleTheme}
                aria-label="auto"
                aria-live="polite"
              >
                <span class="relative size-5 sm:absolute sm:top-1/2 sm:left-1/2 sm:-translate-x-1/2 sm:-translate-y-1/2">
                  <IconMoon class="absolute inset-0 size-5 scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                  <IconSunHigh class="absolute inset-0 size-5 scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
                </span>
                <span class="whitespace-nowrap sm:sr-only">Theme</span>
              </button>
            </li>
          )
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  const navState = window as Window & {
    __sonBlogNavCleanup?: () => void;
    __sonBlogNavEventsReady?: boolean;
  };

  function setupNav() {
    navState.__sonBlogNavCleanup?.();

    const menuBtn = document.querySelector<HTMLButtonElement>("#menu-btn");
    const menuItems = document.querySelector<HTMLElement>("#menu-items");
    const navMenu = document.querySelector<HTMLElement>("#nav-menu");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !navMenu || !menuIcon || !closeIcon) return;

    const openLabel = menuBtn.dataset.labelOpen ?? "Open menu";
    const closeLabel = menuBtn.dataset.labelClose ?? "Close menu";
    const abortController = new AbortController();
    const { signal } = abortController;

    const setMenu = (open: boolean) => {
      menuBtn.setAttribute("aria-expanded", String(open));
      menuBtn.setAttribute("aria-label", open ? closeLabel : openLabel);
      menuItems.classList.toggle("hidden", !open);
      menuItems.classList.toggle("grid", open);
      menuIcon.classList.toggle("hidden", open);
      closeIcon.classList.toggle("hidden", !open);
    };

    menuBtn.addEventListener(
      "click",
      event => {
        event.stopPropagation();
        const openMenu = menuBtn.getAttribute("aria-expanded") === "true";
        setMenu(!openMenu);
      },
      { signal }
    );

    menuItems.querySelectorAll("a").forEach(link => {
      link.addEventListener("click", () => setMenu(false), { signal });
    });

    document.addEventListener(
      "click",
      event => {
        const openMenu = menuBtn.getAttribute("aria-expanded") === "true";
        if (!openMenu || navMenu.contains(event.target as Node)) return;
        setMenu(false);
      },
      { signal }
    );

    document.addEventListener(
      "keydown",
      event => {
        if (event.key !== "Escape") return;
        setMenu(false);
        menuBtn.focus();
      },
      { signal }
    );

    window
      .matchMedia("(min-width: 640px)")
      .addEventListener("change", () => setMenu(false), { signal });

    document
      .querySelectorAll<HTMLAnchorElement>("[data-lang-choice]")
      .forEach(link => {
        link.addEventListener(
          "click",
          () => {
            const choice = link.dataset.langChoice;
            if (choice) localStorage.setItem("sonblog:locale", choice);
          },
          { signal }
        );
      });

    navState.__sonBlogNavCleanup = () => abortController.abort();
  }

  setupNav();

  if (!navState.__sonBlogNavEventsReady) {
    document.addEventListener("astro:before-swap", () =>
      navState.__sonBlogNavCleanup?.()
    );
    document.addEventListener("astro:after-swap", setupNav);
    navState.__sonBlogNavEventsReady = true;
  }
</script>

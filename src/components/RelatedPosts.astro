---
import { getCollection } from "astro:content";
import { getPostUrl } from "@/utils/getPostPaths";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { postFilter } from "@/utils/postFilter";
import { slugifyAll } from "@/utils/slugify";

interface Props {
  tags: string[];
  currentId: string;
  series?: string;
}
const { tags, currentId, series } = Astro.props;
const currentCategory = currentId.split("/")[0] ?? "";
const currentTags = new Set(slugifyAll(tags));

const all = getSortedPosts((await getCollection("posts")).filter(postFilter));
const scored = all
  .filter(p => p.id !== currentId)
  .map(p => ({
    p,
    score:
      slugifyAll(p.data.tags).filter((tag: string) => currentTags.has(tag))
        .length *
        3 +
      (series && p.data.series === series ? 5 : 0) +
      (p.id.split("/")[0] === currentCategory ? 1 : 0),
  }))
  .filter(x => x.score > 0)
  .sort(
    (a, b) =>
      b.score - a.score ||
      +new Date(b.p.data.pubDatetime) - +new Date(a.p.data.pubDatetime)
  )
  .slice(0, 4);
---

{
  scored.length > 0 && (
    <section class="related-posts">
      <h2>관련 글</h2>
      <ul>
        {scored.map(({ p }) => (
          <li>
            <a href={getPostUrl(p.id, p.filePath, Astro.currentLocale)}>
              {p.data.title}
            </a>
            <p>{p.data.description}</p>
          </li>
        ))}
      </ul>
    </section>
  )
}

<style>
  .related-posts {
    margin: 2rem 0;
  }
  .related-posts h2 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .related-posts ul {
    list-style: none;
    padding: 0;
  }
  .related-posts li {
    margin: 0.7rem 0;
  }
  .related-posts a {
    color: var(--accent);
    text-decoration: none;
  }
  .related-posts a:hover {
    text-decoration: underline;
  }
  .related-posts p {
    color: var(--muted-foreground);
    font-size: 0.88rem;
    margin: 0.15rem 0 0;
  }
</style>

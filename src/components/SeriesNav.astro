---
import { getCollection } from "astro:content";

interface Props {
  series?: string;
  currentId: string;
}
const { series, currentId } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");

let items: any[] = [];
if (series) {
  const all = await getCollection(
    "posts",
    ({ data }) => data.series === series && !data.draft
  );
  items = all.sort(
    (a, b) => (a.data.seriesOrder ?? 999) - (b.data.seriesOrder ?? 999)
  );
}
const pos = items.findIndex(p => p.id === currentId);
---

{
  series && items.length > 1 && pos >= 0 && (
    <details class="series-nav" open>
      <summary>
        시리즈 · {series} ({pos + 1} / {items.length}편)
      </summary>
      <ol>
        {items.map((p, i) =>
          i === pos ? (
            <li>
              <strong>{p.data.title} — 현재 글</strong>
            </li>
          ) : (
            <li>
              <a href={`${base}posts/${p.id}/`}>{p.data.title}</a>
            </li>
          )
        )}
      </ol>
    </details>
  )
}

<style>
  .series-nav {
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--muted);
    padding: 0.75rem 1rem;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }
  .series-nav summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--accent);
  }
  .series-nav ol {
    margin: 0.75rem 0 0;
    padding-left: 1.5rem;
  }
  .series-nav li {
    margin: 0.3rem 0;
  }
  .series-nav a {
    text-decoration: none;
  }
  .series-nav a:hover {
    text-decoration: underline;
  }
</style>

---
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import IconCalendar from "@/assets/icons/IconCalendar.svg";
import config from "@/config";
import { useTranslations } from "@/i18n";
import {
  getGeneratedPostDatetime,
  hasGeneratedPostDatetime,
  toDate,
} from "@/utils/postDatetime";

dayjs.extend(utc);
dayjs.extend(timezone);

type Props = {
  class?: string;
  size?: "sm" | "lg";
  pubDatetime: string | Date;
  timezone?: string;
  modDatetime?: string | Date | null;
  postId?: string;
};

const {
  pubDatetime,
  modDatetime,
  postId,
  size = "sm",
  class: className = "",
  timezone: postTimezone,
} = Astro.props;

const t = useTranslations(Astro.currentLocale);

const generatedDatetime = getGeneratedPostDatetime(postId);
const publishedDatetime = toDate(pubDatetime) ?? new Date(pubDatetime);
const modifiedDatetime = toDate(modDatetime);

const isModified =
  modifiedDatetime && modifiedDatetime.getTime() > publishedDatetime.getTime();

const rawDatetime = isModified
  ? modifiedDatetime
  : (generatedDatetime ?? publishedDatetime);
const datetime = dayjs(rawDatetime).tz(postTimezone ?? config.site.timezone);

const date = datetime.format("D MMM, YYYY");
const sourceDate =
  rawDatetime instanceof Date ? rawDatetime : new Date(rawDatetime);
const hasExplicitTime =
  (!isModified && hasGeneratedPostDatetime(postId)) ||
  sourceDate.getUTCHours() !== 0 ||
  sourceDate.getUTCMinutes() !== 0 ||
  sourceDate.getUTCSeconds() !== 0 ||
  sourceDate.getUTCMilliseconds() !== 0;
const displayDate = hasExplicitTime
  ? `${date} · ${datetime.format("HH:mm")}`
  : date;
---

<div
  class:list={[
    "text-muted-foreground flex items-center gap-x-2 whitespace-nowrap",
    className,
  ]}
>
  <IconCalendar
    class:list={[
      "inline-block size-6 min-w-5.5",
      { "scale-90": size === "sm" },
    ]}
  />
  {
    isModified && (
      <span class:list={["text-sm", { "sm:text-base": size === "lg" }]}>
        {t.post.updatedAt}:
      </span>
    )
  }
  <time
    class:list={["text-sm", { "sm:text-base": size === "lg" }]}
    datetime={datetime.toISOString()}
  >
    {displayDate}
  </time>
</div>

---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";
import { topics } from "@/data/topics";

const { posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");
const topicSummaries = topics.map(topic => {
  const topicTags = new Set(topic.tags.map(tag => tag.toLowerCase()));
  const count = posts.filter(post => {
    const filePath = post.filePath ?? "";
    const inCategory = filePath.includes(`/posts/${topic.slug}/`);
    const hasTag = post.data.tags.some(tag => topicTags.has(tag.toLowerCase()));
    return inCategory || hasTag;
  }).length;

  return { ...topic, count };
});
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section id="hero" class="border-border border-b pt-6 pb-7 sm:pt-8 sm:pb-8">
      <p
        class="font-app text-accent text-xs font-semibold tracking-[0.2em] uppercase"
      >
        AI Engineer
      </p>
      <h1 class="mt-2 mb-2 inline-block text-3xl font-bold sm:text-5xl">
        손성준
      </h1>
      <p class="font-app text-muted-foreground text-sm leading-6 sm:text-base">
        LLM Serving · AI Search · MCP Agents · DevOps
      </p>

      <p class="mt-5 max-w-2xl text-sm leading-7 sm:text-base sm:leading-8">
        LLM 서빙, AI 검색엔진, RAG, MCP 에이전트, Kubernetes 인프라를 다루는
        기술 블로그입니다. 커머스 검색엔진에서 출발해 AI 에이전트
        플랫폼(XGEN)까지, 실전에서 직접 만들고 운영한 경험을 기록합니다.
      </p>

      <div
        class="font-app mt-5 grid grid-cols-3 gap-3 text-sm sm:flex sm:flex-wrap sm:items-baseline sm:gap-x-6 sm:gap-y-1"
      >
        <span>
          <strong class="text-accent text-base">{posts.length}+</strong>
          <span class="text-muted-foreground">기술 글</span>
        </span>
        <span>
          <strong class="text-accent text-base">4</strong>
          <span class="text-muted-foreground">전문 영역</span>
        </span>
        <span>
          <strong class="text-accent text-base">11</strong>
          <span class="text-muted-foreground">오픈소스</span>
        </span>
      </div>

      <div
        class="mt-6 grid grid-cols-2 items-center gap-3 sm:flex sm:flex-wrap"
      >
        <a
          href={getRelativeLocaleUrl(locale, "portfolio")}
          class="bg-accent text-accent-foreground rounded-md px-4 py-2 text-center text-sm font-medium transition hover:opacity-90"
        >
          Portfolio
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "posts")}
          class="border-border hover:border-accent hover:text-accent rounded-md border px-4 py-2 text-center text-sm font-medium transition"
        >
          Posts
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "topics")}
          class="border-border hover:border-accent hover:text-accent rounded-md border px-4 py-2 text-center text-sm font-medium transition"
        >
          Topics
        </a>
        <a
          href="https://github.com/SonAIengine"
          target="_blank"
          rel="noopener"
          class="border-border hover:border-accent hover:text-accent rounded-md border px-4 py-2 text-center text-sm font-medium transition"
        >
          GitHub
        </a>
        <a
          target="_blank"
          href={`${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`}
          class="hover:text-accent col-span-2 inline-flex justify-center py-1 sm:col-span-1 sm:ms-1 sm:inline-block sm:py-0"
          aria-label="RSS Feed"
          title="RSS Feed"
        >
          <IconRss
            width={18}
            height={18}
            class="stroke-accent inline-block stroke-[2.5] rtl:-rotate-90"
          />
          <span class="sr-only">RSS Feed</span>
        </a>
      </div>
    </section>

    <section id="expertise" class="border-border border-b py-7 sm:py-8">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div>
          <p
            class="font-app text-accent text-xs font-semibold tracking-wide uppercase"
          >
            Topics
          </p>
          <h2 class="mt-1 text-xl font-semibold tracking-wide sm:text-2xl">
            관심사별로 바로 읽기
          </h2>
        </div>
        <a
          href={getRelativeLocaleUrl(locale, "topics")}
          class="text-accent text-sm underline decoration-dashed underline-offset-4"
        >
          전체 토픽
        </a>
      </div>
      <div class="mt-5 grid gap-3 sm:grid-cols-2">
        {
          topicSummaries.map(topic => (
            <a
              href={getRelativeLocaleUrl(locale, `topics/${topic.slug}`)}
              class="border-border hover:border-accent/70 group rounded-md border p-3 transition sm:p-4"
            >
              <div class="flex items-start justify-between gap-3">
                <h3 class="group-hover:text-accent text-base leading-tight font-semibold sm:text-lg">
                  {topic.title}
                </h3>
                <span class="font-app text-accent text-sm font-semibold whitespace-nowrap">
                  {topic.count}
                </span>
              </div>
              <p class="text-muted-foreground mt-2 text-xs leading-5 sm:text-sm sm:leading-6">
                {topic.eyebrow}
              </p>
            </a>
          ))
        }
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-8 pb-6 sm:pt-12",
            { "border-border border-b": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-xl font-semibold tracking-wide sm:text-2xl">
            {t.home.featured}
          </h2>
          <ul class="mt-5 grid gap-4 sm:grid-cols-2">
            {featuredPosts.map(data => (
              <Card variant="h3" tone="featured" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-8 pb-6 sm:pt-12">
          <h2 class="text-xl font-semibold tracking-wide sm:text-2xl">
            {t.home.recentPosts}
          </h2>
          <ul class="border-border mt-3 divide-y border-y">
            {recentPosts.slice(0, postsConfig.perIndex).map(data => (
              <Card variant="h3" tone="compact" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
        {t.home.allPosts}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>

---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import config from "@/config";
import { topics } from "@/data/topics";

const locale = Astro.currentLocale ?? config.site.lang;
const posts = getSortedPosts(await getCollection("posts"));

function topicPosts(topic: (typeof topics)[number]) {
  const tagSet = new Set(topic.tags.map(tag => tag.toLowerCase()));
  return posts.filter(post => {
    const filePath = post.filePath ?? "";
    const inCategory = filePath.includes(`/posts/${topic.slug}/`);
    const hasTag = post.data.tags.some(tag => tagSet.has(tag.toLowerCase()));
    return inCategory || hasTag;
  });
}
---

<Layout
  title={`Topics | ${config.site.title}`}
  description="SON BLOG의 AI, 검색엔진, 풀스택, DevOps 주제별 기술 글 허브"
>
  <Header />

  <Breadcrumb />

  <Main
    pageTitle="Topics"
    pageDesc="관심 영역별로 대표 글과 최신 글을 빠르게 탐색합니다."
  >
    <div class="grid gap-5 sm:grid-cols-2">
      {
        topics.map(topic => {
          const count = topicPosts(topic).length;
          return (
            <a
              href={getRelativeLocaleUrl(locale, `topics/${topic.slug}`)}
              class="border-border hover:border-accent focus-outline block rounded-md border p-5 transition"
            >
              <p class="text-accent font-app text-xs font-semibold tracking-wide uppercase">
                {topic.eyebrow}
              </p>
              <h2 class="mt-2 text-xl font-semibold">{topic.title}</h2>
              <p class="mt-3 text-sm">{topic.description}</p>
              <p class="text-muted-foreground mt-4 text-sm">{count} posts</p>
            </a>
          );
        })
      }
    </div>
  </Main>

  <Footer />
</Layout>

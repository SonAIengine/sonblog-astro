  }
}
@media screen and (max-width: 400px) {
.pf-hero {
    padding: 2rem 0.8rem 1.8rem;
  }
.pf-hero-greeting {
    font-size: 0.78rem;
  }
.pf-hero-keywords {
    font-size: 0.72rem;
  }
.pf-hero-stats {
    gap: 1rem;
  }
.pf-hero-stat-num {
    font-size: 1.1rem;
  }
.pf-hero-stat-label {
    font-size: 0.65rem;
  }
.pf-section {
    padding: 1.5rem 0.8rem 0;
  }
.pf-expertise-card {
    padding: 1rem;
  }
.pf-card-techs li {
    width: 100%;
    font-size: 0.75rem;
  }
.pf-project-content {
    padding: 1rem;
  }
.pf-project--featured h3 {
    font-size: 0.95rem;
  }
.pf-project-desc {
    font-size: 0.76rem;
  }
.pf-footer {
    padding: 1.5rem 0.8rem 1.2rem;
  }
}
/* ============================================
   HERO SECTION (Home Page)
   ============================================ */

.hero {
  background: linear-gradient(135deg, #1a237e 0%, #283593 30%, #3949ab 60%, #5c6bc0 100%);
  padding: 2.5rem 2rem 2rem;
  text-align: center;
  margin: -1.2rem -1.2rem 1.2rem -1.2rem;
  border-radius: 0 0 0.8rem 0.8rem;
  position: relative;
  overflow: hidden;
}
.hero h1 {
  color: #ffffff;
  font-size: 1.5rem;
  font-weight: 700;
  margin: 0 0 0.2rem 0;
  letter-spacing: -0.02em;
  border: none;
  padding: 0;
}
/* === Dark Mode Home Page === */

[data-md-color-scheme="slate"] .hero {
  background: linear-gradient(135deg, #0d1117 0%, #161b22 30%, #1a237e 60%, #283593 100%);
}
/* ============================================
   PORTFOLIO PAGE — Modern Dark Theme
   ============================================ */

/* 포트폴리오 페이지 md-content 너비 제한 해제 */
.md-content__inner:has(.pf-hero) {
  max-width: none;
}
/* ── Hero ── */
.pf-hero {
  background: #0a0e1a;
  padding: 5rem 2rem 3.5rem;
  text-align: center;
  margin: -1.2rem -1.2rem 0 -1.2rem;
  position: relative;
  overflow: hidden;
}
.pf-hero-mesh {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 20% 50%, rgba(99, 102, 241, 0.18) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 20%, rgba(139, 92, 246, 0.12) 0%, transparent 50%),
    radial-gradient(ellipse at 60% 80%, rgba(59, 130, 246, 0.08) 0%, transparent 50%);
  pointer-events: none;
}
.pf-hero-inner {
  position: relative;
  z-index: 1;
  max-width: 700px;
  margin: 0 auto;
}
.pf-hero-greeting {
  color: #818cf8;
  font-size: 0.85rem;
  font-weight: 500;
  font-family: var(--md-code-font);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin: 0 0 0.8rem 0;
}
.pf-hero-name {
  color: #e2e8f0 !important;
  font-size: clamp(2rem, 5vw, 3.2rem);
  font-weight: 800;
  margin: 0 0 0.6rem 0;
  letter-spacing: -0.03em;
  border: none;
  padding: 0;
  line-height: 1.1;
}
.pf-hero-keywords {
  color: rgba(148, 163, 184, 0.7);
  font-size: 0.9rem;
  font-family: var(--md-code-font);
  margin: 0 0 2rem 0;
}
.pf-hero-stats {
  display: flex;
  justify-content: center;
  gap: 2.5rem;
  margin-bottom: 2rem;
}
.pf-hero-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.2rem;
}
.pf-hero-stat-num {
  color: #e2e8f0;
  font-size: 1.5rem;
  font-weight: 700;
  font-family: var(--md-code-font);
}
.pf-hero-stat-label {
  color: #64748b;
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.pf-hero-emails {
  margin: 0 0 1.2rem 0;
  color: rgba(148, 163, 184, 0.7);
  font-size: 0.78rem;
  font-family: var(--md-code-font);
  text-align: center;
}
.pf-hero-socials {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.2rem;
}
a.pf-social-icon,
a.pf-social-icon:link,
a.pf-social-icon:visited {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(99, 102, 241, 0.08);
  border: 1px solid rgba(99, 102, 241, 0.2);
  color: rgba(199, 210, 254, 0.8) !important;
  text-decoration: none !important;
  transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}
a.pf-social-icon svg {
  width: 20px;
  height: 20px;
}
a.pf-social-icon:hover {
  background: rgba(99, 102, 241, 0.2);
  border-color: rgba(99, 102, 241, 0.5);
  color: #e0e7ff !important;
  transform: translateY(-3px);
  box-shadow: 0 4px 16px rgba(99, 102, 241, 0.2);
}
.pf-hero-links {
  display: flex;
  justify-content: center;
  gap: 0.8rem;
}
a.pf-hero-btn,
a.pf-hero-btn:link,
a.pf-hero-btn:visited {
  display: inline-block;
  color: #c7d2fe !important;
  font-size: 0.78rem;
  font-weight: 500;
  background: rgba(99, 102, 241, 0.08);
  border: 1px solid rgba(99, 102, 241, 0.25);
  border-radius: 8px;
  padding: 0.5rem 1.2rem;
  text-decoration: none !important;
  transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}
a.pf-hero-btn:hover {
  background: rgba(99, 102, 241, 0.15);
  border-color: rgba(99, 102, 241, 0.5);
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(99, 102, 241, 0.15);
}
a.pf-hero-btn--primary,
a.pf-hero-btn--primary:link,
a.pf-hero-btn--primary:visited {
  background: rgba(99, 102, 241, 0.2) !important;
  border-color: rgba(99, 102, 241, 0.4) !important;
  color: #e0e7ff !important;
}
/* 언어 토글(KR ⇄ EN) — 점선 테두리로 다른 동작임을 구분 */
a.pf-hero-btn--lang,
a.pf-hero-btn--lang:link,
a.pf-hero-btn--lang:visited {
  background: transparent !important;
  border-style: dashed !important;
  border-color: rgba(99, 102, 241, 0.4) !important;
  color: #a5b4fc !important;
  letter-spacing: 0.02em;
}
a.pf-hero-btn--lang:hover {
  background: rgba(99, 102, 241, 0.12) !important;
  border-style: solid !important;
}
/* ── Section Common ── */
.pf-section {
  max-width: 1280px;
  margin: 0 auto;
  padding: 3rem 2rem 0;
}
.pf-section-header {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  margin-bottom: 1.5rem;
}
.pf-section-num {
  font-family: var(--md-code-font);
  font-size: 0.85rem;
  font-weight: 600;
  color: #6366f1;
}
.pf-section-title {
  font-size: 1.2rem;
  font-weight: 700;
  color: #1e293b;
  margin: 0;
  padding: 0;
  border: none;
  text-decoration: none;
  white-space: nowrap;
}
.pf-section-line {
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, #e2e8f0, transparent);
}
/* ── About ── */
.pf-about-text {
  font-size: 0.92rem;
  color: #475569;
  line-height: 1.85;
  margin: 0 0 1.5rem 0;
}
.pf-chips-group {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}
.pf-chips-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.4rem;
}
.pf-chips-label {
  font-size: 0.68rem;
  font-weight: 600;
  color: #94a3b8;
  min-width: 85px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-family: var(--md-code-font);
}
.pf-chip {
  font-size: 0.72rem;
  color: #6366f1;
  background: rgba(99, 102, 241, 0.08);
  border: 1px solid rgba(99, 102, 241, 0.15);
  padding: 0.2rem 0.6rem;
  border-radius: 6px;
  font-weight: 500;
  transition: all 0.2s ease;
}
.pf-chip:hover {
  background: rgba(99, 102, 241, 0.15);
  border-color: rgba(99, 102, 241, 0.3);
  transform: translateY(-1px);
}
/* ── Expertise Grid ── */
.pf-expertise-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
}
.pf-expertise-card {
  display: flex;
  flex-direction: column;
  padding: 1.25rem;
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  text-decoration: none !important;
  color: inherit;
  transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  position: relative;
  overflow: hidden;
}
.pf-expertise-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 10%;
  right: 10%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(99, 102, 241, 0.3), transparent);
  opacity: 0;
  transition: opacity 0.3s ease;
}
.pf-expertise-card:hover {
  transform: translateY(-4px);
  box-shadow:
    0 4px 6px rgba(0, 0, 0, 0.04),
    0 10px 24px rgba(99, 102, 241, 0.08);
  border-color: rgba(99, 102, 241, 0.2);
  text-decoration: none !important;
}
.pf-expertise-card:hover::after {
  opacity: 1;
}
.pf-expertise-icon {
  width: 36px;
  height: 36px;
  color: #6366f1;
  margin-bottom: 0.8rem;
}
.pf-expertise-icon svg {
  width: 100%;
  height: 100%;
}
.pf-expertise-card h3 {
  font-size: 0.95rem;
  font-weight: 700;
  margin: 0 0 0.4rem 0;
  padding: 0;
  border: none;
  color: #1e293b;
  text-decoration: none;
}
.pf-card-count {
  font-size: 0.68rem;
  color: #6366f1;
  font-weight: 600;
  font-family: var(--md-code-font);
  margin-bottom: 0.6rem;
}
.pf-card-techs {
  list-style: none;
  margin: 0;
  padding: 0;
  flex-grow: 1;
}
.pf-card-techs li {
  font-size: 0.78rem;
  color: #64748b;
  line-height: 1.6;
  margin-bottom: 0.1rem;
  padding-left: 0.8rem;
  position: relative;
}
.pf-card-techs li::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0.6em;
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: #c7d2fe;
}
/* ── Projects ── */
.pf-project {
  display: flex;
  flex-direction: column;
  padding: 1px;
  border-radius: 12px;
  text-decoration: none !important;
  color: inherit;
  position: relative;
  overflow: hidden;
  background: #e2e8f0;
  transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
}
/* Spotlight gradient that follows cursor */
.pf-project::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(
    500px circle at var(--mx, 50%) var(--my, 50%),
    rgba(99, 102, 241, 0.25),
    transparent 40%
  );
  opacity: 0;
  transition: opacity 0.4s ease;
  z-index: 1;
}
.pf-project:hover::before {
  opacity: 1;
}
.pf-project-content {
  position: relative;
  z-index: 2;
  background: #ffffff;
  border-radius: 11px;
  padding: 1.5rem;
  flex: 1;
  display: flex;
  flex-direction: column;
}
.pf-project-content .pf-project-desc {
  flex: 1;
}
.pf-project:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.06);
  text-decoration: none !important;
}
/* Featured */
.pf-project--featured {
  margin-bottom: 1rem;
  background: linear-gradient(135deg, #6366f1, #8b5cf6, #a78bfa);
}
.pf-project--featured::before {
  background: radial-gradient(
    600px circle at var(--mx, 50%) var(--my, 50%),
    rgba(255, 255, 255, 0.12),
    transparent 40%
  );
}
.pf-project--featured .pf-project-content {
  background: linear-gradient(135deg, #fafafe, #f5f3ff);
}
.pf-project-glow {
  display: none;
}
.pf-project-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0.6rem;
}
.pf-project-label {
  font-size: 0.68rem;
  font-weight: 600;
  color: #6366f1;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-family: var(--md-code-font);
}
.pf-project h3 {
  font-size: 1rem;
  font-weight: 700;
  margin: 0 0 0.5rem 0;
  padding: 0;
  border: none;
  color: #1e293b;
  text-decoration: none;
}
.pf-project--featured h3 {
  font-size: 1.2rem;
  color: #312e81;
}
.pf-project-tags {
  display: flex;
  gap: 0.35rem;
  flex-wrap: wrap;
  margin-bottom: 0.6rem;
}
.pf-tag {
  font-size: 0.62rem;
  font-weight: 600;
  padding: 0.15rem 0.55rem;
  border-radius: 100px;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  border: 1px solid transparent;
}
.pf-tag--search { background: rgba(59, 130, 246, 0.08); color: #3b82f6; border-color: rgba(59, 130, 246, 0.15); }
.pf-tag--ai { background: rgba(168, 85, 247, 0.08); color: #a855f7; border-color: rgba(168, 85, 247, 0.15); }
.pf-tag--fullstack { background: rgba(34, 197, 94, 0.08); color: #16a34a; border-color: rgba(34, 197, 94, 0.15); }
.pf-tag--devops { background: rgba(249, 115, 22, 0.08); color: #ea580c; border-color: rgba(249, 115, 22, 0.15); }
.pf-project-desc {
  font-size: 0.85rem;
  color: #64748b;
  line-height: 1.7;
  margin: 0 0 0.8rem 0;
}
.pf-project-posts {
  font-size: 0.68rem;
  color: #6366f1;
  font-weight: 600;
  font-family: var(--md-code-font);
}
.md-typeset .pf-project-highlights,
.pf-project-highlights {
  list-style: none !important;
  margin: 0 0 0.8rem 0 !important;
  padding: 0 !important;
}
.md-typeset .pf-project-highlights li,
.pf-project-highlights li {
  list-style: none !important;
  font-size: 0.8rem;
  color: #475569;
  line-height: 1.65;
  margin-bottom: 0.3rem;
  padding-left: 1rem;
  position: relative;
  margin-left: 0 !important;
}
.md-typeset .pf-project-highlights li::marker,
.pf-project-highlights li::marker {
  content: none !important;
  font-size: 0 !important;
}
.pf-project-highlights li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0.6em;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: #6366f1;
}
.pf-project-highlights li strong {
  color: #1e293b;
  font-weight: 700;
}
.pf-project-stack-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}
.pf-stack-item {
  font-size: 0.68rem;
  color: #94a3b8;
  font-family: var(--md-code-font);
  padding: 0.15rem 0.5rem;
  background: rgba(148, 163, 184, 0.08);
  border: 1px solid rgba(148, 163, 184, 0.12);
  border-radius: 4px;
}
.pf-project-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}
/* ── Tech Stack ── */
.pf-stack-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}
.pf-stack-col {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.pf-stack-label {
  font-size: 0.72rem;
  font-weight: 600;
  color: #94a3b8;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-family: var(--md-code-font);
  margin: 0 0 0.3rem 0;
  padding: 0 0 0.4rem 0;
  border: none;
  border-bottom: 1px solid #e2e8f0;
  text-decoration: none;
}
.pf-stack-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}
.pf-stack-chip {
  display: inline-flex;
  align-items: center;
  font-size: 0.78rem;
  color: #475569;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  padding: 0.3rem 0.7rem;
  border-radius: 8px;
  font-weight: 500;
  transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  cursor: default;
}
.pf-stack-chip:hover {
  background: rgba(99, 102, 241, 0.06);
  border-color: rgba(99, 102, 241, 0.2);
  color: #6366f1;
  transform: translateY(-2px);
  box-shadow: 0 4px 8px rgba(99, 102, 241, 0.08);
}
/* ── Timeline ── */
.pf-timeline {
  position: relative;
  padding-left: 0;
  max-width: 700px;
}
.pf-timeline::before {
  content: "";
  position: absolute;
  left: 6px;
  top: 8px;
  bottom: 8px;
  width: 2px;
  background: linear-gradient(to bottom, #6366f1, #c7d2fe, transparent);
  border-radius: 2px;
}
.pf-tl-item {
  position: relative;
  padding-left: 2.5rem;
  margin-bottom: 2rem;
}
.pf-tl-item:last-child {
  margin-bottom: 0;
}
.pf-tl-dot {
  position: absolute;
  left: 0;
  top: 6px;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: #6366f1;
  border: 3px solid #f8fafc;
  box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
  z-index: 1;
}
.pf-tl-card {
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-radius: 10px;
  padding: 1.2rem 1.5rem;
  transition: all 0.3s ease;
}
.pf-tl-card:hover {
  border-color: rgba(99, 102, 241, 0.2);
  box-shadow: 0 4px 16px rgba(99, 102, 241, 0.06);
  transform: translateX(4px);
}
.pf-tl-year {
  font-size: 1.1rem;
  font-weight: 800;
  color: #6366f1;
  font-family: var(--md-code-font);
  display: block;
  margin-bottom: 0.6rem;
}
.pf-tl-list {
  list-style: none;
  margin: 0;
  padding: 0;
}
.pf-tl-list li {
  margin-bottom: 0.35rem;
  padding-left: 0.8rem;
  position: relative;
}
.pf-tl-list li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0.55em;
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: #c7d2fe;
}
.pf-tl-list li:last-child {
  margin-bottom: 0;
}
.pf-tl-list a {
  font-size: 0.85rem;
  color: #475569;
  text-decoration: none;
  transition: color 0.2s;
}
.pf-tl-list a:hover {
  color: #6366f1;
}
/* ── Footer ── */
.pf-footer {
  max-width: 1280px;
  margin: 0 auto;
  padding: 3rem 2rem 2rem;
  text-align: center;
}
.pf-footer-stats {
  color: #94a3b8;
  font-size: 0.78rem;
  font-family: var(--md-code-font);
  margin-bottom: 1rem;
}
.pf-footer-sep {
  margin: 0 0.4rem;
}
.pf-footer-links {
  display: flex;
  justify-content: center;
  gap: 0.8rem;
}
a.pf-footer-btn,
a.pf-footer-btn:link,
a.pf-footer-btn:visited {
  display: inline-block;
  font-size: 0.78rem;
  font-weight: 500;
  color: #6366f1 !important;
  background: rgba(99, 102, 241, 0.06);
  border: 1px solid rgba(99, 102, 241, 0.15);
  border-radius: 8px;
  padding: 0.4rem 1rem;
  text-decoration: none !important;
  transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}
a.pf-footer-btn:hover {
  background: rgba(99, 102, 241, 0.12);
  border-color: rgba(99, 102, 241, 0.3);
  transform: translateY(-2px);
  box-shadow: 0 4px 8px rgba(99, 102, 241, 0.1);
}
/* ── Open Source Grid ── */
.pf-oss-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.2rem;
}
a.pf-oss-card,
a.pf-oss-card:link,
a.pf-oss-card:visited {
  display: flex;
  flex-direction: column;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  padding: 1.4rem;
  text-decoration: none !important;
  color: inherit !important;
  transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}
a.pf-oss-card:hover {
  border-color: rgba(99, 102, 241, 0.4);
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(99, 102, 241, 0.08);
}
.pf-oss-header {
  display: flex;
  align-items: center;
  justify-content: space-between;

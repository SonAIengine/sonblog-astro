---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
const posts = await getCollection("posts");
const has = (c: string) => (p: any) => p.data.tags.map((t: string) => t.toLowerCase()).includes(c);
const pc = {
  total: posts.length,
  ai: posts.filter(has("ai")).length,
  search_engine: posts.filter(has("search engine")).length,
  full_stack: posts.filter(has("full stack")).length,
  devops: posts.filter(has("devops")).length,
};
---


  color: #6b7280;
  font-family: var(--font-app);
  font-size: 0.68rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}
.pf-hero-emails {
  margin: 0 0 1.3rem;
  color: #8a8f98;
  font-family: var(--font-app);
  font-size: 0.76rem;
}
.pf-hero-socials {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 0.9rem;
  margin-bottom: 1.4rem;
}
a.pf-social-icon,
a.pf-social-icon:link,
a.pf-social-icon:visited {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(20, 184, 166, 0.08);
  border: 1px solid rgba(20, 184, 166, 0.22);
  color: #99f6e4 !important;
  text-decoration: none !important;
  transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), background 0.3s, border-color 0.3s, box-shadow 0.3s;
}
a.pf-social-icon svg {
  width: 20px;
  height: 20px;
}
a.pf-social-icon:hover {
  background: rgba(20, 184, 166, 0.18);
  border-color: rgba(20, 184, 166, 0.5);
  color: #ccfbf1 !important;
  transform: translateY(-3px);
  box-shadow: 0 6px 18px rgba(20, 184, 166, 0.22);
}
.pf-hero-links {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 0.7rem;
}
a.pf-hero-btn,
a.pf-hero-btn:link,
a.pf-hero-btn:visited {
  display: inline-block;
  padding: 0.5rem 1.2rem;
  border-radius: 8px;
  font-family: var(--font-app);
  font-size: 0.76rem;
  font-weight: 500;
  color: #99f6e4 !important;
  background: rgba(20, 184, 166, 0.08);
  border: 1px solid rgba(20, 184, 166, 0.25);
  text-decoration: none !important;
  transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), background 0.3s, border-color 0.3s, box-shadow 0.3s;
}
a.pf-hero-btn:hover {
  background: rgba(20, 184, 166, 0.16);
  border-color: rgba(20, 184, 166, 0.5);
  transform: translateY(-2px);
  box-shadow: 0 6px 14px rgba(20, 184, 166, 0.18);
}
a.pf-hero-btn--primary,
a.pf-hero-btn--primary:link,
a.pf-hero-btn--primary:visited {
  background: rgba(20, 184, 166, 0.22) !important;
  border-color: rgba(20, 184, 166, 0.45) !important;
  color: #ccfbf1 !important;
}
a.pf-hero-btn--lang,
a.pf-hero-btn--lang:link,
a.pf-hero-btn--lang:visited {
  background: transparent !important;
  border-style: dashed !important;
  border-color: rgba(20, 184, 166, 0.45) !important;
  color: #5eead4 !important;
}
a.pf-hero-btn--lang:hover {
  background: rgba(20, 184, 166, 0.12) !important;
  border-style: solid !important;
}

/* ── Section ── */
.pf-section {
  max-width: 1200px;
  margin: 0 auto;
  padding: 3.25rem 2rem 0;
}
.pf-section-header {
  display: flex;
  align-items: center;
  gap: 0.85rem;
  margin-bottom: 1.6rem;
}
.pf-section-num {
  font-family: var(--font-app);
  font-size: 0.82rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--accent);
}
.pf-section-title {
  margin: 0;
  padding: 0;
  border: none;
  white-space: nowrap;
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--foreground);
}
.pf-section-line {
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, var(--border), transparent);
}

/* ── About ── */
.pf-about-text {
  margin: 0 0 1.4rem;
  color: var(--muted-foreground);
  font-size: 0.95rem;
  line-height: 1.85;
}
.pf-about-text a {
  color: var(--accent);
  text-decoration: underline;
  text-decoration-style: dashed;
  text-underline-offset: 3px;
}
.pf-chips-group {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
  margin-top: 1.8rem;
}
.pf-chips-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.4rem;
}
.pf-chips-label {
  min-width: 92px;
  font-family: var(--font-app);
  font-size: 0.66rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted-foreground);
}
.pf-chip {
  padding: 0.22rem 0.6rem;
  border-radius: 6px;
  font-size: 0.74rem;
  font-weight: 500;
  color: var(--accent);
  background: var(--pf-tint);
  border: 1px solid color-mix(in srgb, var(--accent) 22%, transparent);
  transition: transform 0.2s, background 0.2s, border-color 0.2s;
}
.pf-chip:hover {
  background: var(--pf-tint-strong);
  border-color: var(--pf-border-accent);
  transform: translateY(-1px);
}

/* ── Expertise ── */
.pf-expertise-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
}
.pf-expertise-card {
  display: flex;
  flex-direction: column;
  padding: 1.35rem;
  border-radius: 14px;
  background: var(--pf-surface);
  border: 1px solid var(--border);
  color: inherit;
  text-decoration: none !important;
  position: relative;
  overflow: hidden;
  transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.35s, box-shadow 0.35s, background 0.35s;
}
.pf-expertise-card::after {
  content: "";
  position: absolute;
  top: 0;
  left: 12%;
  right: 12%;
  height: 1px;
  background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--accent) 45%, transparent), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}
.pf-expertise-card:hover {
  transform: translateY(-4px);
  border-color: var(--pf-border-accent);
  background: var(--pf-surface-hover);
  box-shadow: 0 12px 28px var(--pf-shadow);
}
.pf-expertise-card:hover::after {
  opacity: 1;
}
.pf-expertise-icon {
  width: 36px;
  height: 36px;
  color: var(--accent);
  margin-bottom: 0.85rem;
}
.pf-expertise-icon svg {
  width: 100%;
  height: 100%;
}
.pf-expertise-card h3 {
  margin: 0 0 0.4rem;
  padding: 0;
  border: none;
  font-size: 0.96rem;
  font-weight: 700;
  color: var(--foreground);
}
.pf-card-count {
  margin-bottom: 0.7rem;
  font-family: var(--font-app);
  font-size: 0.66rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--accent);
}
.pf-card-techs {
  list-style: none;
  margin: 0;
  padding: 0;
  flex-grow: 1;
}
.pf-card-techs li {
  position: relative;
  padding-left: 0.85rem;
  margin-bottom: 0.12rem;
  font-size: 0.79rem;
  line-height: 1.6;
  color: var(--muted-foreground);
}
.pf-card-techs li::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0.62em;
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: color-mix(in srgb, var(--accent) 55%, transparent);
}

/* ── Projects ── */
.pf-project {
  display: flex;
  flex-direction: column;
  padding: 1px;
  border-radius: 14px;
  background: var(--border);
  position: relative;
  overflow: hidden;
  color: inherit;
  text-decoration: none !important;
  transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.35s;
}
.pf-project::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 1;
  opacity: 0;
  transition: opacity 0.4s;
  background: radial-gradient(
    500px circle at var(--mx, 50%) var(--my, 50%),
    color-mix(in srgb, var(--accent) 30%, transparent),
    transparent 40%
  );
}
.pf-project:hover::before {
  opacity: 1;
}
.pf-project:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
}
.pf-project-content {
  position: relative;
  z-index: 2;
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 1.6rem;
  border-radius: 13px;
  background: var(--pf-surface);
}
.pf-project-content .pf-project-desc {
  flex: 1;
}
.pf-project-glow {
  display: none;
}
.pf-project--featured {
  margin-bottom: 1rem;
  background: linear-gradient(135deg, #0f766e, #14b8a6, #2dd4bf);
}
.pf-project--featured::before {
  background: radial-gradient(
    600px circle at var(--mx, 50%) var(--my, 50%),
    rgba(255, 255, 255, 0.14),
    transparent 40%
  );
}
.pf-project--featured .pf-project-content {
  background: color-mix(in srgb, var(--accent) 6%, var(--background));
}
.pf-project--featured h3 {
  font-size: 1.22rem;
  color: var(--foreground);
}
.pf-project-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0.6rem;
}
.pf-project-label {
  font-family: var(--font-app);
  font-size: 0.66rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--accent);
}
.pf-project h3 {
  margin: 0 0 0.5rem;
  padding: 0;
  border: none;
  font-size: 1.02rem;
  font-weight: 700;
  color: var(--foreground);
}
.pf-project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  margin-bottom: 0.6rem;
}
.pf-tag {
  padding: 0.16rem 0.55rem;
  border-radius: 100px;
  font-size: 0.62rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  border: 1px solid transparent;
}
.pf-tag--search { background: rgba(59, 130, 246, 0.13); color: #3b82f6; border-color: rgba(59, 130, 246, 0.28); }
.pf-tag--ai { background: rgba(168, 85, 247, 0.13); color: #a855f7; border-color: rgba(168, 85, 247, 0.28); }
.pf-tag--fullstack { background: rgba(34, 197, 94, 0.13); color: #22c55e; border-color: rgba(34, 197, 94, 0.28); }
.pf-tag--devops { background: rgba(249, 115, 22, 0.13); color: #f97316; border-color: rgba(249, 115, 22, 0.28); }
.pf-project-desc {
  margin: 0 0 0.85rem;
  font-size: 0.86rem;
  line-height: 1.7;
  color: var(--muted-foreground);
}
.pf-project-posts {
  font-family: var(--font-app);
  font-size: 0.66rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--accent);
}
.pf-project-highlights {
  list-style: none !important;
  margin: 0 0 0.85rem !important;
  padding: 0 !important;
}
.pf-project-highlights li {
  position: relative;
  list-style: none !important;
  margin: 0 0 0.32rem !important;
  padding-left: 1rem;
  font-size: 0.81rem;
  line-height: 1.65;
  color: var(--muted-foreground);
}
.pf-project-highlights li::marker {
  content: none !important;
}
.pf-project-highlights li::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0.6em;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--accent);
}
.pf-project-highlights li strong {
  color: var(--foreground);
  font-weight: 700;
}
.pf-project-stack-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}
.pf-stack-item {
  padding: 0.16rem 0.5rem;
  border-radius: 5px;
  font-family: var(--font-app);
  font-size: 0.67rem;
  color: var(--muted-foreground);
  background: color-mix(in srgb, var(--foreground) 5%, transparent);
  border: 1px solid var(--border);
}
.pf-project-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}

/* ── Open Source ── */
.pf-oss-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.1rem;
}
a.pf-oss-card,
a.pf-oss-card:link,
a.pf-oss-card:visited {
  display: flex;
  flex-direction: column;
  padding: 1.4rem;
  border-radius: 14px;
  background: var(--pf-surface);
  border: 1px solid var(--border);
  color: inherit !important;
  text-decoration: none !important;
  transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.3s, box-shadow 0.3s;
}
a.pf-oss-card:hover {
  border-color: color-mix(in srgb, var(--accent) 40%, transparent);
  transform: translateY(-3px);
  box-shadow: 0 10px 26px var(--pf-shadow);
}
.pf-oss-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0.7rem;
}
.pf-oss-icon {
  width: 22px;
  height: 22px;
  color: var(--accent);
}
.pf-oss-lang {
  font-family: var(--font-app);
  font-size: 0.68rem;
  font-weight: 500;
  color: var(--accent);
  background: var(--pf-tint);
  padding: 0.15rem 0.5rem;
  border-radius: 5px;
}
.pf-oss-card h4 {
  margin: 0 0 0.4rem;
  font-size: 1rem;
  font-weight: 700;
  color: var(--foreground);
}
.pf-oss-card p {
  margin: 0 0 1rem;
  flex-grow: 1;
  font-size: 0.81rem;
  line-height: 1.55;
  color: var(--muted-foreground);
}
.pf-oss-meta {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  margin-top: auto;
}
.pf-oss-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-family: var(--font-app);
  font-size: 0.7rem;
  font-weight: 500;
  color: var(--accent);
  background: var(--pf-tint);
  border: 1px solid color-mix(in srgb, var(--accent) 22%, transparent);
  padding: 0.3rem 0.65rem;
  border-radius: 6px;
}
.pf-oss-badge::before {
  content: "$";
  opacity: 0.55;
  font-weight: 600;
}

/* ── Tech Stack ── */
.pf-stack-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}
.pf-stack-col {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.pf-stack-label {
  margin: 0 0 0.4rem;
  padding: 0 0 0.45rem;
  border: none;
  border-bottom: 1px solid var(--border);
  font-family: var(--font-app);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted-foreground);
}
.pf-stack-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}
.pf-stack-chip {
  display: inline-flex;
  align-items: center;
  padding: 0.3rem 0.7rem;
  border-radius: 8px;
  font-size: 0.78rem;
  font-weight: 500;
  color: var(--muted-foreground);
  background: var(--pf-surface);
  border: 1px solid var(--border);
  cursor: default;
  transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1), background 0.25s, border-color 0.25s, color 0.25s, box-shadow 0.25s;
}
.pf-stack-chip:hover {
  color: var(--accent);
  background: var(--pf-tint);
  border-color: var(--pf-border-accent);
  transform: translateY(-2px);
  box-shadow: 0 4px 10px var(--pf-shadow);
}

/* ── Timeline ── */
.pf-timeline {
  position: relative;
  max-width: 720px;
}
.pf-timeline::before {
  content: "";
  position: absolute;
  left: 6px;
  top: 8px;
  bottom: 8px;
  width: 2px;
  border-radius: 2px;
  background: linear-gradient(to bottom, var(--accent), color-mix(in srgb, var(--accent) 30%, transparent), transparent);
}
.pf-tl-item {
  position: relative;
  padding-left: 2.5rem;
  margin-bottom: 2rem;
}
.pf-tl-item:last-child {
  margin-bottom: 0;
}
.pf-tl-dot {
  position: absolute;
  left: 0;
  top: 6px;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: var(--accent);
  border: 3px solid var(--background);
  box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 30%, transparent);
}
.pf-tl-card {
  padding: 1.25rem 1.5rem;
  border-radius: 12px;
  background: var(--pf-surface);
  border: 1px solid var(--border);
  transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
}
.pf-tl-card:hover {
  border-color: var(--pf-border-accent);
  box-shadow: 0 6px 18px var(--pf-shadow);
  transform: translateX(4px);
}
.pf-tl-year {
  display: block;
  margin-bottom: 0.6rem;
  font-family: var(--font-app);
  font-size: 1.1rem;
  font-weight: 800;
  letter-spacing: -0.02em;
  color: var(--accent);
  font-feature-settings: "tnum" 1;
}
.pf-tl-list {
  list-style: none;
  margin: 0;
  padding: 0;
}
.pf-tl-list li {
  position: relative;
  padding-left: 0.85rem;
  margin-bottom: 0.35rem;
  font-size: 0.86rem;
  line-height: 1.6;
  color: var(--muted-foreground);
}
.pf-tl-list li:last-child {
  margin-bottom: 0;
}
.pf-tl-list li::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0.58em;
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: color-mix(in srgb, var(--accent) 50%, transparent);
}
.pf-tl-list a {
  color: inherit;
  text-decoration: none;
  transition: color 0.2s;
}
.pf-tl-list a:hover {
  color: var(--accent);
}

/* ── Experience ── */
.pf-exp-list { display: flex; flex-direction: column; gap: 1rem; }
.pf-exp-card {
  padding: 1.5rem 1.6rem;
  border-radius: 14px;
  background: var(--pf-surface);
  border: 1px solid var(--border);
  transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.3s, box-shadow 0.3s;
}
.pf-exp-card:hover {
  border-color: var(--pf-border-accent);
  box-shadow: 0 8px 20px var(--pf-shadow);
  transform: translateY(-2px);
}
.pf-exp-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 0.3rem 1rem;
  flex-wrap: wrap;
  margin-bottom: 0.15rem;
}
.pf-exp-role { margin: 0; padding: 0; border: none; font-size: 1rem; font-weight: 700; color: var(--foreground); }
.pf-exp-period { font-family: var(--font-app); font-size: 0.72rem; font-weight: 500; letter-spacing: 0.02em; color: var(--accent); white-space: nowrap; }
.pf-exp-company { display: block; margin-bottom: 0.85rem; font-size: 0.82rem; color: var(--muted-foreground); }
.pf-exp-card .pf-tl-list li { margin-bottom: 0.4rem; }

/* ── Education ── */
.pf-edu-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
.pf-edu-card {
  padding: 1.4rem;
  border-radius: 14px;
  background: var(--pf-surface);
  border: 1px solid var(--border);
  transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.3s, box-shadow 0.3s;
}
.pf-edu-card:hover { border-color: var(--pf-border-accent); box-shadow: 0 8px 20px var(--pf-shadow); transform: translateY(-2px); }
.pf-edu-period { font-family: var(--font-app); font-size: 0.68rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--accent); }
.pf-edu-school { margin: 0.45rem 0 0.25rem; padding: 0; border: none; font-size: 0.96rem; font-weight: 700; color: var(--foreground); }
.pf-edu-degree { font-size: 0.8rem; line-height: 1.5; color: var(--muted-foreground); }
.pf-edu-extra { display: flex; flex-direction: column; gap: 0.6rem; margin-top: 1.4rem; }
@media (max-width: 600px) {
  .pf-edu-grid { grid-template-columns: 1fr; }
  .pf-exp-card { padding: 1.25rem 1.3rem; }
}

/* ── By the Numbers ── */
.pf-numbers-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.1rem;
}
.pf-number-card {
  text-align: center;
  padding: 1.7rem 1rem;
  border-radius: 14px;
  background: var(--pf-surface);
  border: 1px solid var(--border);
  transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.3s, box-shadow 0.3s;
}
.pf-number-card:hover {
  border-color: var(--pf-border-accent);
  transform: translateY(-2px);
  box-shadow: 0 8px 20px var(--pf-shadow);
}
.pf-number-value {
  display: block;
  margin-bottom: 0.3rem;
  font-family: var(--font-app);
  font-size: 1.85rem;
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: -0.02em;
  color: var(--accent);
  font-feature-settings: "tnum" 1;
}
.pf-number-label {
  display: block;
  font-size: 0.76rem;
  line-height: 1.35;
  color: var(--muted-foreground);
}

/* ── Footer ── */
.pf-footer {

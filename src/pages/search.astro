---
import { getRelativeLocaleUrl } from "astro:i18n";
import "@pagefind/default-ui/css/ui.css";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import { getAssetPath } from "@/utils/withBase";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

// Redirect to 404 page if `search` feature is not enabled
const notFoundUrl = getRelativeLocaleUrl(locale, "404");
if (config.features.search !== "pagefind" && notFoundUrl) {
  return Astro.rewrite(notFoundUrl);
}

const backUrl = config.features.showBackButton
  ? `${Astro.url.pathname}`
  : getRelativeLocaleUrl(locale, "");

const pagefindBundlePath = getAssetPath("pagefind/");
const searchApiBase =
  import.meta.env.PUBLIC_SEARCH_API_BASE || "https://search.infoedu.co.kr";
const searchQualityPath = getRelativeLocaleUrl(locale, "search-quality");

const t = useTranslations(locale);
---

<Layout title={`${t.pages.searchTitle} | ${config.site.title}`}>
  <Header />

  <Main pageTitle={t.pages.searchTitle} hidePageTitle class="mt-8 sm:mt-10">
    <div
      id="pagefind-search"
      data-backurl={backUrl}
      data-bundle-path={pagefindBundlePath}
    >
    </div>

    <section
      id="semantic-search"
      class="semantic-search-panel"
      data-search-api={searchApiBase}
      aria-live="polite"
      hidden
    >
      <div class="semantic-search-header">
        <div class="semantic-search-title">
          <h2>Hybrid Search</h2>
          <a href={searchQualityPath} class="semantic-quality-link">Quality</a>
        </div>
        <span id="semantic-search-meta" class="semantic-search-meta"></span>
      </div>
      <div id="semantic-search-stages" class="semantic-search-stages"></div>
      <ol id="semantic-search-results" class="semantic-result-list"></ol>
    </section>
  </Main>

  <Footer />
</Layout>

<script>
  function initSearch() {
    type SemanticExplain = {
      matchedTerms?: string[];
      termCount?: number;
      lexicalRatio?: number;
      titleRatio?: number;
      tagRatio?: number;
      exactPhrase?: boolean;
      rawScore?: number;
      boostedScore?: number;
      signals?: string[];
    };

    type SemanticResult = {
      url: string;
      title: string;
      score?: number;
      confidence?: string;
      sources?: string[];
      explain?: SemanticExplain;
    };

    const pageFindSearch: HTMLElement | null =
      document.querySelector("#pagefind-search");
    const semanticSearch =
      document.querySelector<HTMLElement>("#semantic-search");
    const semanticResults = document.querySelector<HTMLOListElement>(
      "#semantic-search-results"
    );
    const semanticMeta = document.querySelector<HTMLElement>(
      "#semantic-search-meta"
    );
    const semanticStages = document.querySelector<HTMLElement>(
      "#semantic-search-stages"
    );

    if (!pageFindSearch) return;

    const bundlePath = pageFindSearch?.dataset?.bundlePath;
    if (!bundlePath) return;

    const params = new URLSearchParams(window.location.search);
    const trackedEvents = new Set<string>();
    const semanticState: {
      query: string;
      ready: boolean;
      ok: boolean;
      urls: Set<string>;
    } = {
      query: "",
      ready: false,
      ok: false,
      urls: new Set(),
    };

    function clearSemanticSearch() {
      semanticSearch?.setAttribute("hidden", "");
      semanticResults?.replaceChildren();
      if (semanticMeta) semanticMeta.textContent = "";
      semanticStages?.replaceChildren();
      semanticState.query = "";
      semanticState.ready = false;
      semanticState.ok = false;
      semanticState.urls = new Set();
      applyPagefindConfidenceGate("");
    }

    function goatcounter() {
      return (
        window as typeof window & {
          goatcounter?: {
            count?: (event: { path: string; title?: string }) => void;
          };
        }
      ).goatcounter;
    }

    function queryKey(query: string) {
      let hash = 2166136261;
      for (let index = 0; index < query.length; index += 1) {
        hash ^= query.charCodeAt(index);
        hash = Math.imul(hash, 16777619);
      }
      return (hash >>> 0).toString(36);
    }

    function countEvent(path: string, title: string) {
      if (trackedEvents.has(path)) return;
      trackedEvents.add(path);
      goatcounter()?.count?.({ path, title });
    }

    function trackSearchQuery(source: string, query: string) {
      const q = query.trim().toLowerCase();
      if (q.length < 2) return;
      countEvent(
        `/event/search/${source}/query/${queryKey(q)}?qlen=${q.length}`,
        `${source} search query`
      );
    }

    function trackSearchResults(
      source: string,
      query: string,
      count: number,
      ms?: number
    ) {
      const q = query.trim().toLowerCase();
      if (q.length < 2) return;
      const rounded = Math.min(count, 20);
      const latency = typeof ms === "number" ? `&ms=${Math.round(ms)}` : "";
      countEvent(
        `/event/search/${source}/results/${queryKey(q)}?count=${rounded}&qlen=${q.length}${latency}`,
        `${source} search results`
      );
    }

    function trackSearchClick(source: string, query: string, href: string) {
      const q = query.trim().toLowerCase();
      if (q.length < 2) return;
      const target = new URL(href, window.location.origin).pathname;
      countEvent(
        `/event/search/${source}/click/${queryKey(q)}?target=${encodeURIComponent(target)}`,
        `${source} search click`
      );
    }

    const onIdle = window.requestIdleCallback || (cb => setTimeout(cb, 1));

    onIdle(async () => {
      // @ts-expect-error — Missing types for @pagefind/default-ui package.
      const { PagefindUI } = await import("@pagefind/default-ui");

      // Display warning inn dev mode
      if (import.meta.env.DEV) {
        pageFindSearch.innerHTML = `
            <div class="bg-muted/75 rounded p-4 space-y-4 mb-4">
              <p><strong>DEV mode Warning! </strong>You need to build the project at least once to see the search results during development.</p>
              <code class="block bg-black text-white px-2 py-1 rounded">pnpm run build</code>
            </div>
          `;
      }

      // Init pagefind ui
      const search = new PagefindUI({
        element: "#pagefind-search",
        bundlePath,
        showImages: false,
        showSubResults: true,
        processTerm: function (term: string) {
          trackSearchQuery("pagefind", term);
          params.set("q", term); // Update the `q` parameter in the URL
          history.replaceState(history.state, "", "?" + params.toString()); // Push the new URL without reloading

          const backUrl =
            pageFindSearch?.dataset?.backurl ?? window.location.pathname;
          sessionStorage.setItem("backUrl", `${backUrl}?${params.toString()}`);

          return term;
        },
      });

      // If search param exists (eg: search?q=astro), trigger search
      const query = params.get("q");
      if (query) {
        search.triggerSearch(query);
      } else {
        clearSemanticSearch();
      }

      mountSemanticSearchPanel();

      // Reset search param if search input is cleared
      const searchInput = document.querySelector(".pagefind-ui__search-input");
      const clearButton = document.querySelector(".pagefind-ui__search-clear");
      searchInput?.addEventListener("input", resetSearchParam);
      clearButton?.addEventListener("click", () => {
        window.setTimeout(() => {
          if ((searchInput as HTMLInputElement | null)?.value.trim() === "") {
            history.replaceState(history.state, "", window.location.pathname);
            clearSemanticSearch();
          }
        }, 0);
      });
      attachSemanticSearch(searchInput as HTMLInputElement | null, query);
      observePagefindResults(searchInput as HTMLInputElement | null);

      function resetSearchParam(e: Event) {
        if ((e.target as HTMLInputElement)?.value.trim() === "") {
          history.replaceState(history.state, "", window.location.pathname);
          clearSemanticSearch();
        }
      }
    });

    function mountSemanticSearchPanel() {
      if (!pageFindSearch || !semanticSearch) return;
      const drawer = pageFindSearch.querySelector(".pagefind-ui__drawer");
      if (drawer && drawer.previousElementSibling !== semanticSearch) {
        drawer.insertAdjacentElement("beforebegin", semanticSearch);
        ensurePagefindGateMessage();
        return;
      }

      const form = pageFindSearch.querySelector(".pagefind-ui__form");
      if (!form || form.nextElementSibling === semanticSearch) return;
      form.insertAdjacentElement("afterend", semanticSearch);
      ensurePagefindGateMessage();
    }

    function ensurePagefindGateMessage() {
      if (!pageFindSearch) return null;
      let message = pageFindSearch.querySelector<HTMLElement>(
        "#pagefind-confidence-empty"
      );
      if (!message) {
        message = document.createElement("p");
        message.id = "pagefind-confidence-empty";
        message.className = "pagefind-confidence-empty";
        message.setAttribute("hidden", "");
        message.textContent = "검색 결과가 없습니다.";
      }

      const anchor =
        semanticSearch?.parentElement === pageFindSearch
          ? semanticSearch
          : pageFindSearch.querySelector(".pagefind-ui__form");
      if (anchor && message.previousElementSibling !== anchor) {
        anchor.insertAdjacentElement("afterend", message);
      }
      return message;
    }

    function canonicalPath(href: string | null | undefined) {
      if (!href) return "";
      try {
        const url = new URL(href, window.location.origin);
        const path = url.pathname.replace(/\/$/, "");
        return path ? `${path}/` : "/";
      } catch {
        return href.split("#")[0].replace(/\/$/, "") + "/";
      }
    }

    function resetPagefindResults(drawer: Element | null) {
      drawer?.removeAttribute("hidden");
      pageFindSearch
        ?.querySelectorAll<HTMLElement>(".pagefind-ui__result")
        .forEach(result => {
          result.hidden = false;
          delete result.dataset.semanticFiltered;
        });
    }

    function applyPagefindConfidenceGate(query: string) {
      if (!pageFindSearch) return;
      const q = query.trim();
      const drawer = pageFindSearch.querySelector(".pagefind-ui__drawer");
      const emptyMessage = ensurePagefindGateMessage();

      if (!q || !semanticState.ready || semanticState.query !== q) {
        resetPagefindResults(drawer);
        emptyMessage?.setAttribute("hidden", "");
        return;
      }

      if (!semanticState.ok) {
        resetPagefindResults(drawer);
        emptyMessage?.setAttribute("hidden", "");
        return;
      }

      const results = pageFindSearch.querySelectorAll<HTMLElement>(
        ".pagefind-ui__result"
      );

      if (semanticState.urls.size === 0) {
        drawer?.setAttribute("hidden", "");
        results.forEach(result => {
          result.hidden = true;
          result.dataset.semanticFiltered = "true";
        });
        emptyMessage?.removeAttribute("hidden");
        return;
      }

      emptyMessage?.setAttribute("hidden", "");
      let visibleCount = 0;
      results.forEach(result => {
        const href = result.querySelector<HTMLAnchorElement>(
          ".pagefind-ui__result-title a"
        )?.href;
        const visible = semanticState.urls.has(canonicalPath(href));
        result.hidden = !visible;
        result.dataset.semanticFiltered = visible ? "false" : "true";
        if (visible) visibleCount += 1;
      });

      if (results.length > 0 && visibleCount === 0) {
        drawer?.setAttribute("hidden", "");
      } else {
        drawer?.removeAttribute("hidden");
      }
    }

    function attachSemanticSearch(
      searchInput: HTMLInputElement | null,
      initialQuery: string | null
    ) {
      if (
        !searchInput ||
        !semanticSearch ||
        !semanticResults ||
        !semanticMeta ||
        searchInput.dataset.semanticBound === "true"
      ) {
        return;
      }

      const searchBox = semanticSearch;
      const resultsList = semanticResults;
      const meta = semanticMeta;

      searchInput.dataset.semanticBound = "true";
      let timer: number | undefined;
      let controller: AbortController | null = null;

      const searchFromInput = () => {
        const q = searchInput.value.trim();
        window.clearTimeout(timer);
        timer = window.setTimeout(() => runSemanticSearch(q), 260);
      };

      searchInput.addEventListener("input", searchFromInput);
      if (searchInput.value.trim()) {
        searchFromInput();
      } else if (initialQuery?.trim()) {
        runSemanticSearch(initialQuery.trim());
      }

      async function runSemanticSearch(q: string) {
        if (q.length < 2) {
          searchBox.hidden = true;
          resultsList.replaceChildren();
          meta.textContent = "";
          semanticStages?.replaceChildren();
          semanticState.query = "";
          semanticState.ready = false;
          semanticState.ok = false;
          semanticState.urls = new Set();
          applyPagefindConfidenceGate("");
          controller?.abort();
          return;
        }

        controller?.abort();
        controller = new AbortController();
        semanticState.query = q;
        semanticState.ready = false;
        semanticState.ok = false;
        semanticState.urls = new Set();
        applyPagefindConfidenceGate(q);

        try {
          trackSearchQuery("semantic", q);
          const base = searchBox.dataset.searchApi;
          if (!base) return;
          const response = await fetch(
            `${base}/search?q=${encodeURIComponent(q)}&limit=5&explain=true`,
            { signal: controller.signal }
          );
          if (!response.ok) throw new Error("search failed");
          const data = await response.json();
          renderSemanticResults(data, q);
        } catch (error) {
          if ((error as DOMException).name === "AbortError") return;
          semanticState.query = q;
          semanticState.ready = true;
          semanticState.ok = false;
          semanticState.urls = new Set();
          applyPagefindConfidenceGate(q);
          searchBox.hidden = true;
          resultsList.replaceChildren();
          meta.textContent = "";
          semanticStages?.replaceChildren();
        }
      }
    }

    function observePagefindResults(searchInput: HTMLInputElement | null) {
      if (
        !searchInput ||
        !pageFindSearch ||
        pageFindSearch.dataset.telemetryBound === "true"
      ) {
        return;
      }

      pageFindSearch.dataset.telemetryBound = "true";
      let timer: number | undefined;

      const report = () => {
        window.clearTimeout(timer);
        timer = window.setTimeout(() => {
          const q = searchInput.value.trim();
          if (q.length < 2) return;
          applyPagefindConfidenceGate(q);
          const count = pageFindSearch.querySelectorAll(
            ".pagefind-ui__result:not([hidden])"
          ).length;
          trackSearchResults("pagefind", q, count);
        }, 500);
      };

      const observer = new MutationObserver(report);
      observer.observe(pageFindSearch, { childList: true, subtree: true });
      pageFindSearch.addEventListener("click", event => {
        const target = event.target as Element | null;
        const link = target?.closest<HTMLAnchorElement>(
          ".pagefind-ui__result-title a, .pagefind-ui__result-link"
        );
        if (link?.href) {
          trackSearchClick("pagefind", searchInput.value, link.href);
        }
      });
    }

    function renderSemanticResults(
      data: {
        results?: SemanticResult[];
        ms?: number;
        stages?: string[];
      },
      query: string
    ) {
      if (!semanticSearch || !semanticResults || !semanticMeta) return;
      const results = data.results ?? [];
      semanticState.query = query;
      semanticState.ready = true;
      semanticState.ok = true;
      semanticState.urls = new Set(
        results.map(result => canonicalPath(result.url))
      );
      applyPagefindConfidenceGate(query);
      trackSearchResults("semantic", query, results.length, data.ms);
      if (results.length === 0) {
        semanticSearch.hidden = true;
        semanticResults.replaceChildren();
        semanticMeta.textContent = "";
        semanticStages?.replaceChildren();
        return;
      }

      semanticMeta.textContent =
        typeof data.ms === "number"
          ? `${results.length} · ${Math.round(data.ms)}ms`
          : `${results.length}`;
      renderSemanticStages(data.stages ?? []);

      const isCompact = window.matchMedia("(max-width: 639px)").matches;
      const visibleLimit = isCompact ? 1 : 3;
      const visibleResults = results.slice(0, visibleLimit);
      semanticResults.replaceChildren(
        ...visibleResults.map((result, index) =>
          renderSemanticResultItem(result, index + 1, query)
        )
      );

      if (results.length > visibleResults.length) {
        const more = document.createElement("li");
        more.className = "semantic-result-more";

        const details = document.createElement("details");
        const summary = document.createElement("summary");
        summary.textContent = `${results.length - visibleResults.length}개 더 보기`;

        const extraList = document.createElement("ol");
        extraList.className = "semantic-extra-list";
        extraList.replaceChildren(
          ...results
            .slice(visibleResults.length)
            .map((result, index) =>
              renderSemanticResultItem(
                result,
                visibleResults.length + index + 1,
                query
              )
            )
        );

        details.append(summary, extraList);
        more.append(details);
        semanticResults.append(more);
      }

      semanticSearch.hidden = false;
    }

    function renderSemanticResultItem(
      result: SemanticResult,
      rankNumber: number,
      query: string
    ) {
      const item = document.createElement("li");
      item.className = "semantic-result-item";

      const rank = document.createElement("span");
      rank.className = "semantic-result-rank";
      rank.textContent = String(rankNumber);

      const link = document.createElement("a");
      link.href = result.url;
      link.className = "semantic-result-link";
      link.textContent = result.title;
      link.addEventListener("click", () => {
        trackSearchClick("semantic", query, result.url);
      });

      const score = document.createElement("span");
      score.className = "semantic-result-score";
      score.textContent =
        typeof result.score === "number" ? result.score.toFixed(3) : "";

      const meta = renderResultSignals(result.sources ?? [], score);
      item.append(rank, link, meta);

      const explain = renderResultExplain(result.explain);
      if (explain) item.append(explain);

      return item;
    }

    function renderResultSignals(sources: string[], score: HTMLElement) {
      const meta = document.createElement("span");
      meta.className = "semantic-result-signals";
      meta.append(score);

      for (const source of sources.slice(0, 2)) {
        const badge = document.createElement("span");
        badge.className = "semantic-result-source";
        badge.textContent = sourceLabel(source);
        meta.append(badge);
      }

      return meta;
    }

    function renderResultExplain(explain: SemanticExplain | undefined) {
      if (!explain) return null;
      const details = document.createElement("details");
      details.className = "semantic-result-explain";

      const summary = document.createElement("summary");
      summary.textContent = "근거";

      const chips = document.createElement("div");
      chips.className = "semantic-explain-chips";

      const terms = explain.matchedTerms ?? [];
      chips.append(
        explainChip("terms", `${terms.length}/${explain.termCount ?? 0}`),
        explainChip("lex", ratioLabel(explain.lexicalRatio)),
        explainChip("title", ratioLabel(explain.titleRatio)),
        explainChip("tag", ratioLabel(explain.tagRatio))
      );

      if (typeof explain.rawScore === "number") {
        chips.append(explainChip("raw", explain.rawScore.toFixed(3)));
      }

      for (const signal of (explain.signals ?? []).slice(0, 3)) {
        chips.append(explainChip(signalLabel(signal), "hit"));
      }

      if (terms.length > 0) {
        const matched = document.createElement("p");
        matched.className = "semantic-explain-terms";
        matched.textContent = terms.join(" · ");
        details.append(summary, chips, matched);
      } else {
        details.append(summary, chips);
      }

      return details;
    }

    function explainChip(label: string, value: string) {
      const chip = document.createElement("span");
      chip.className = "semantic-explain-chip";
      chip.textContent = `${label} ${value}`;
      return chip;
    }

    function ratioLabel(value: number | undefined) {
      if (typeof value !== "number") return "0%";
      return `${Math.round(value * 100)}%`;
    }

    function signalLabel(signal: string) {
      const labels: Record<string, string> = {
        title: "title",
        tag: "tag",
        phrase: "phrase",
        exact_url: "exact",
        lexical_evidence: "evidence",
      };
      return labels[signal] ?? signal;
    }

    function renderSemanticStages(stages: string[]) {
      if (!semanticStages) return;
      const preferred = [
        "fts",
        "vector",
        "evidence",
        "korean_morphology",
        "query_normalized",
        "lexical_fallback",
        "doc_rank",
        "confidence_gate",
      ];
      const ordered = [
        ...preferred.filter(stage => stages.includes(stage)),
        ...stages.filter(stage => !preferred.includes(stage)),
      ].slice(0, 7);

      semanticStages.replaceChildren(
        ...ordered.map(stage => {
          const chip = document.createElement("span");
          chip.className = "semantic-stage-chip";
          chip.textContent = stageLabel(stage);
          return chip;
        })
      );
    }

    function sourceLabel(source: string) {
      const labels: Record<string, string> = {
        lexical: "Lexical",
        synaptic: "Graph",
        equrl: "Exact",
      };
      return labels[source] ?? source;
    }

    function stageLabel(stage: string) {
      const labels: Record<string, string> = {
        evidence: "Hybrid",
        fts: "BM25",
        vector: "Vector",
        korean_morphology: "Kiwi",
        query_normalized: "Alias",
        lexical_fallback: "Lexical",
        doc_rank: "Rank",
        confidence_gate: "Gate",
        operator_and: "AND",
        operator_or: "OR",
        equrl_filter: "EQURL",
        rerank: "Rerank",
      };
      return labels[stage] ?? stage;
    }
  }

  document.addEventListener("astro:after-swap", () => {
    const pagefindSearch = document.querySelector("#pagefind-search");

    // if pagefind search form already exists, don't initialize search component
    if (pagefindSearch && pagefindSearch.querySelector("form")) return;

    initSearch();
  });
  initSearch();
</script>

<style is:global>
  #pagefind-search
    .pagefind-ui__result
    > .pagefind-ui__result-inner
    > .pagefind-ui__result-title::before {
    display: inline-flex;
    align-items: center;
    min-height: 1.75rem;
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    padding: 0.25rem 0.55rem;
    font-family: var(--font-app);
    font-size: 0.75rem;
    line-height: 1;
    color: var(--muted-foreground);
    background: var(--background);
  }

  .semantic-search-panel {
    margin-block: 0.65rem 0.9rem;
    padding: 0.75rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    background: color-mix(in oklab, var(--muted) 26%, transparent);
  }

  .semantic-search-panel[hidden] {
    display: none !important;
  }

  .semantic-search-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.45rem;
  }

  .semantic-search-header h2 {
    font-family: var(--font-app);
    font-size: 0.875rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .semantic-search-title {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: 0.5rem;
  }

  .semantic-quality-link {
    flex: 0 0 auto;
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.14rem 0.44rem;
    color: var(--muted-foreground);
    font-family: var(--font-app);
    font-size: 0.66rem;
    font-weight: 700;
    line-height: 1.2;
    text-decoration: none;
  }

  .semantic-quality-link:hover {
    border-color: color-mix(in oklab, var(--accent) 45%, var(--border));
    color: var(--accent);
  }

  .semantic-search-meta {
    flex: 0 0 auto;
    color: var(--muted-foreground);
    font-family: var(--font-app);
    font-size: 0.75rem;
    line-height: 1;
  }

  .semantic-search-stages {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.55rem;
  }

  .semantic-stage-chip {
    display: inline-flex;
    align-items: center;
    min-height: 1.45rem;
    border: 1px solid color-mix(in oklab, var(--accent) 28%, var(--border));
    border-radius: 999px;
    padding: 0.18rem 0.48rem;
